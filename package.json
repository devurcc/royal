{
  "name": "maintenance",
  "version": "1.0.0",
  "description": "Maintenance page with animated typography and background music",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:assets && vite build",
    "generate:assets": "node scripts/generate-assets.mjs",
    "preview": "vite preview",
    "check": "npm run lint && npm run format:check",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint src/ --max-warnings=0",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "format": "prettier --write \"src/**/*.{js,json,css,html,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,json,css,html,md}\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "devurcc",
  "license": "MIT",
  "type": "module",
  "private": "true",
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/youtube": "^0.3.0",
    "@vitejs/plugin-legacy": "^8.2.0",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.49.0",
    "vite": "^8.1.4",
    "vite-plugin-html-inject": "^1.1.2",
    "vite-plugin-image-optimizer": "^2.0.3"
  },
  "dependencies": {
    "animejs": "^3.2.2"
  }
}
